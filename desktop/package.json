{
  "name": "likeslack-desktop",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.likeslack.desktop",
    "productName": "LikeSlack",
    "forceCodeSigning": false,
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.png",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "LikeSlack.exe"
    },
    "files": [
      "main.js",
      "preload.js",
      "config.json",
      "icon.png"
    ]
  }
}
