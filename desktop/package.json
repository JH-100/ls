{
  "name": "likeslack-desktop",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.likeslack.desktop",
    "productName": "LikeSlack",
    "win": {
      "target": "portable",
      "icon": "../public/assets/icon-512.png"
    },
    "portable": {
      "artifactName": "LikeSlack.exe"
    }
  }
}
