{
  "name": "kk-desktop",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win portable",
    "build:mac": "electron-builder --mac zip",
    "build:all": "electron-builder --win portable --mac zip",
    "build": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.kk.desktop",
    "productName": "KK",
    "forceCodeSigning": false,
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.png",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "icon.png",
      "identity": null,
      "artifactName": "KK-mac-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "KK.exe"
    },
    "files": [
      "main.js",
      "preload.js",
      "config.json",
      "icon.png"
    ]
  }
}
